# Configuración de Producción - KLICUS
# Copiar este archivo como .env en el servidor de Conexcol

# Servidor
PORT=4000 # O el puerto que asigne cPanel (usualmente detectado automáticamente)
NODE_ENV=production

# Base de Datos (Credenciales de cPanel)
MYSQL_HOST=localhost
MYSQL_USER=tu_usuario_db
MYSQL_PASSWORD=tu_password_seguro
MYSQL_DATABASE=tu_nombre_db

# Autenticación (NextAuth)
# Cambiar a la URL real: https://tudominio.com
NEXTAUTH_URL=https://tudominio.com
# Generar una clave fuerte con: openssl rand -base64 32
NEXTAUTH_SECRET=cambiar_por_una_clave_aleatoria_muy_larga

# Firebase Admin SDK — notificaciones push (FCM)
# Genera el JSON en Firebase Console > Configuración del proyecto > Cuentas de servicio
# Luego convierte a una línea: cat firebase-admin.json | jq -c . | pbcopy
# Pega el resultado completo (una sola línea JSON) como valor de esta variable.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"tu-proyecto",...}

# Mercado Pago — obtén tu token en https://www.mercadopago.com.co/developers
# Producción: APP_USR-...   |   Sandbox: TEST-...
MP_ACCESS_TOKEN=APP_USR-tu_access_token_de_produccion
# URL del webhook registrada en tu cuenta de Mercado Pago (opcional, por defecto usa NEXTAUTH_URL)
# MP_WEBHOOK_URL=https://tudominio.com

# CORS — orígenes web permitidos (separados por coma, sin espacios al final)
# Solo aplica a browsers; la app Flutter nativa no envía Origin y no necesita estar aquí.
# Ejemplo con múltiples orígenes: https://klicus.com,https://www.klicus.com
ALLOWED_ORIGINS=https://tudominio.com

# Firebase Storage — imágenes de anuncios persistentes (no se pierden en deploys)
# Encuéntralo en Firebase Console > Storage > nombre del bucket (ej: tu-proyecto.appspot.com)
FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com

# Optimización
NEXT_SHARP_PATH=/home/tu_usuario/klicus_prod/app/node_modules/sharp
