# KLICUS PRODUCTION ENVIRONMENT VARIABLES
# Copy these to your cPanel Node.js Selector "Environment Variables" section

# Database (Conexcol MySQL)
MYSQL_HOST=localhost
MYSQL_USER=tu_usuario_db
MYSQL_PASSWORD=tu_password_db
MYSQL_DATABASE=tu_nombre_db

# Security & Sessions
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=tu_secreto_generado
NEXTAUTH_URL=https://tu-dominio.com

# Payments (Mercado Pago Production)
MP_ACCESS_TOKEN=tu_access_token_produccion
MP_WEBHOOK_URL=https://tu-dominio.com/api/webhooks/mercadopago
